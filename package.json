{
  "name": "followdraft-skill",
  "version": "0.1.0",
  "description": "Meeting follow-up drafts with action and approval boundaries.",
  "type": "module",
  "bin": {
    "followdraft": "./src/cli.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "SKILL.md",
    "docs",
    "fixtures",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "build": "node scripts/build.js",
    "smoke": "node src/cli.js draft fixtures/meeting-notes.txt --format markdown",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "bash scripts/validate.sh && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "agents",
    "meeting-follow-up",
    "dry-run"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/followdraft-skill.git"
  },
  "homepage": "https://github.com/rogerchappel/followdraft-skill#readme",
  "bugs": {
    "url": "https://github.com/rogerchappel/followdraft-skill/issues"
  }
}
